    {
      "id": "filter-new-leads",
      "name": "Filter New Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [440, 300],
      "disabled": false,
      "parameters": {
        "language": "javaScript",
        "sourceCode": {
          "javaScript": "// Filter leads with LinkedIn URL but not enriched yet\nconst leads = $input.all().filter(item => {\n  const l = item.json;\n  const url = l['LinkedIn URL'] || l.linkedinUrl || l.linkedin_url || '';\n  const status = l.Status || 'New';\n  return url.length > 0 && status === 'New';\n});\n\nif (leads.length === 0) {\n  return [{ json: { message: 'No new leads to enrich', count: 0 } }];\n}\n\nreturn leads.map(item => {\n  const l = item.json;\n  return {\n    json: {\n      leadId: l['Lead ID'] || l.leadId || '',\n      name: l.Name || l.name || '',\n      linkedinUrl: l['LinkedIn URL'] || l.linkedinUrl || l.linkedin_url || '',\n      headline: l.Headline || l.headline || '',\n      company: l.Company || l.company || '',\n      jobTitle: l['Job Title'] || l.jobTitle || '',\n      notes: l.Notes || l.notes || ''\n    }\n  };\n});"
        }
      }
    },
    {
      "id": "if-has-leads",
      "name": "Has Leads?",
      "type": "n8n-nodes-base.if",
