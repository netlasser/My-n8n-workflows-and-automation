    {
      "id": "parse-enrich-result",
      "name": "Parse & Score Enriched Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [1140, 200],
      "disabled": false,
      "parameters": {
        "language": "javaScript",
        "sourceCode": {
          "javaScript": "// Parse Apollo response and compute enrichment score\nconst item = $input.item.json;\nconst person = item.person || {};\nconst org = person.organization || {};\n\nconst enriched = {\n  leadId: item.leadId || '',\n  linkedinUrl: item.linkedinUrl || '',\n  name: [person.first_name, person.last_name].filter(Boolean).join(' ') || item.name,\n  headline: person.headline || item.headline || '',\n  company: org.name || item.company || '',\n  companySize: org.employee_count || '',\n  industry: org.industry || '',\n  jobTitle: person.title || item.jobTitle || '',\n  email: person.email || '',\n  emailStatus: person.email_status || '',\n  phone: person.phone || '',\n  city: person.city || '',\n  state: person.state || '',\n  country: person.country || '',\n  techStack: (org.technology_names || []).join(', '),\n  twitterUrl: person.twitter_url || '',\n  linkedinBio: person.linkedin_bio || person.summary || '',\n  enrichedAt: new Date().toISOString()\n};\n\n// Scoring\nlet score = 0;\nif (enriched.email) score += 3;\nif (enriched.phone) score += 2;\nif (enriched.companySize) score += 1;\nif (enriched.techStack) score += 1;\nif (enriched.jobTitle) score += 1;\n\nenriched.score = score;\nif (score >= 5) enriched.status = 'Hot';\nelse if (score >= 3) enriched.status = 'Warm';\nelse enriched.status = 'Cold';\n\nreturn { json: enriched };"
        }
      }
    },
